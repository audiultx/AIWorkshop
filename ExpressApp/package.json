{
  "name": "express-tailwind-app",
  "version": "1.0.0",
  "description": "Express.js app with Tailwind CSS",
  "main": "src/app.js",
  "scripts": {
    "dev": "node src/app.js",
    "build:css": "tailwindcss -i ./src/input.css -o ./src/public/output.css --watch",
    "build": "npm run build:css && echo 'CSS built successfully!'"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3"
  }
}